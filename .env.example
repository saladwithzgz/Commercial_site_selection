# DeepSeek API 配置文件
# 复制此文件为 .env 并填写实际配置

# ==================== DeepSeek API ====================
# DeepSeek API密钥（必填）
# 获取地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek API基础URL（可选，默认使用官方地址）
# 国内用户如遇网络问题，可配置代理地址
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# DeepSeek模型名称（可选，默认使用deepseek-chat）
# 可用模型：deepseek-chat, deepseek-coder, deepseek-chat-16k
DEEPSEEK_MODEL=deepseek-chat

# API请求超时时间（秒，可选，默认30秒）
DEEPSEEK_TIMEOUT=30

# 温度参数（可选，默认0.7）
# 范围：0-2，越小越确定，越大越随机
DEEPSEEK_TEMPERATURE=0.7

# 最大token数（可选，默认4000）
DEEPSEEK_MAX_TOKENS=4000

# ==================== 应用配置 ====================
# 服务端口（可选，默认5000）
FLASK_PORT=5000

# 调试模式（可选，默认关闭）
FLASK_DEBUG=false

# ==================== 日志配置 ====================
# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
